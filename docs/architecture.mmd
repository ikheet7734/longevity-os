    User["👤 User<br/><i>Voice / Text via Claude Code</i>"]

    %% ── Orchestrator ──
    subgraph ORCH["🏛 御医 Orchestrator"]
        direction TB
        Yuyi["御医<br/>Imperial Physician<br/><i>SKILL.md</i>"]
    end

    %% ── Department Agents ──
    subgraph DEPTS["六科 Department Agents"]
        direction LR
        Shiyi["🍚 食医科<br/>Diet<br/><i>shiyi.md</i>"]
        Daoyin["🏃 导引科<br/>Exercise<br/><i>daoyin.md</i>"]
        Zhenmai["📊 诊脉科<br/>Metrics<br/><i>zhenmai.md</i>"]
        Yanfang["🔬 验方科<br/>Labs<br/><i>yanfang.md</i>"]
        Bencao["🌿 本草科<br/>Supplements<br/><i>bencao.md</i>"]
        Shixiao["📈 试效科<br/>Trial Monitor<br/><i>shixiao.md</i>"]
    end

    %% ── Trial Pipeline ──
    subgraph TRIAL["⚗️ Trial Design Pipeline"]
        direction LR
        Yuanpan["院判<br/>Trial Design<br/><i>yuanpan.md</i>"]
        Yizheng["医正<br/>Review Gate<br/><i>yizheng.md</i>"]
