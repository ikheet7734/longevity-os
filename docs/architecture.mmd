%%{init: {
  'theme': 'base',
  'themeVariables': {
    'fontSize': '14px',
    'fontFamily': 'system-ui, -apple-system, sans-serif',
    'primaryColor': '#FFFFFF',
    'primaryBorderColor': '#DAA520',
    'primaryTextColor': '#333333',
    'lineColor': '#555555',
    'secondaryColor': '#FFF8E7',
    'tertiaryColor': '#F5F5F5',
    'background': '#FFFFFF',
    'mainBkg': '#FFFFFF',
    'nodeBorder': '#DAA520',
    'clusterBkg': '#FAFAFA',
    'clusterBorder': '#CCCCCC',
    'titleColor': '#333333',
    'edgeLabelBackground': '#FFFFFF'
  }
}}%%
graph TB
    %% ── User ──
    User["<b>User</b><br/><i>Voice / Text via Claude Code</i>"]

    %% ── Orchestrator ──
    subgraph ORCH["ORCHESTRATOR"]
        direction TB
        Yuyi["<b>御医</b><br/>Imperial Physician<br/><i>SKILL.md</i>"]
    end

    %% ── Department Agents ──
    subgraph DEPTS["DEPARTMENT AGENTS  六科"]
        direction LR
        Shiyi["<b>食医科</b><br/>Diet<br/><i>shiyi.md</i>"]
        Daoyin["<b>导引科</b><br/>Exercise<br/><i>daoyin.md</i>"]
        Zhenmai["<b>诊脉科</b><br/>Metrics<br/><i>zhenmai.md</i>"]
        Yanfang["<b>验方科</b><br/>Labs<br/><i>yanfang.md</i>"]
        Bencao["<b>本草科</b><br/>Supplements<br/><i>bencao.md</i>"]
        Shixiao["<b>试效科</b><br/>Trial Monitor<br/><i>shixiao.md</i>"]
    end

    %% ── Trial Pipeline ──
    subgraph TRIAL["TRIAL DESIGN PIPELINE"]
        direction LR
        Yuanpan["<b>院判</b><br/>Trial Design<br/><i>yuanpan.md</i>"]
        Yizheng["<b>医正</b><br/>Review Gate<br/><i>yizheng.md</i>"]
        Yuanpan -->|"proposal"| Yizheng
        Yizheng -->|"approve"| Approved(["Trial Approved"])
        Yizheng -->|"reject + feedback"| Yuanpan
    end

    %% ── Reports ──
    Baogao["<b>报告科</b><br/>Reports<br/><i>baogao.md</i>"]

    %% ── Modeling Engine ──
    subgraph ENGINE["MODELING ENGINE"]
        direction LR
        EngineMain["<b>engine.py</b><br/><i>Trend & anomaly<br/>detection</i>"]
        Patterns["<b>patterns.py</b><br/><i>Cross-module<br/>correlation</i>"]
        Causal["<b>causal.py</b><br/><i>Causal inference<br/>& hypothesis</i>"]
    end

    %% ── Infrastructure ──
    DB[("SQLite<br/><b>taiyiyuan.db</b>")]
    Dashboard["<b>Dashboard</b><br/><i>localhost:8420</i>"]

    subgraph APIS["EXTERNAL APIs"]
        direction LR
        USDA["USDA<br/>FoodData Central"]
        PubMed["PubMed"]
        BioRxiv["bioRxiv"]
    end

    %% ── Connections: User <-> Orchestrator ──
    User <-->|"natural language"| Yuyi

    %% ── Connections: Orchestrator -> Agents ──
    Yuyi -->|"dispatch"| Shiyi
    Yuyi -->|"dispatch"| Daoyin
    Yuyi -->|"dispatch"| Zhenmai
    Yuyi -->|"dispatch"| Yanfang
    Yuyi -->|"dispatch"| Bencao
    Yuyi -->|"dispatch"| Shixiao
    Yuyi -->|"dispatch"| Yuanpan
    Yuyi -->|"dispatch"| Baogao

    %% ── Connections: Agents -> DB ──
    Shiyi <-->|"read/write"| DB
    Daoyin <-->|"read/write"| DB
    Zhenmai <-->|"read/write"| DB
    Yanfang <-->|"read/write"| DB
    Bencao <-->|"read/write"| DB
    Shixiao <-->|"read/write"| DB
    Yuanpan <-->|"read"| DB
    Yizheng <-->|"read"| DB
    Baogao <-->|"read"| DB

    %% ── Connections: Modeling Engine ──
    ENGINE <-->|"analysis"| DB
    Baogao -->|"invoke"| ENGINE
    Yuanpan -->|"invoke"| ENGINE
    Shixiao -->|"invoke"| ENGINE

    %% ── Connections: External APIs ──
    Shiyi -.->|"nutrition lookup"| USDA
    Yuanpan -.->|"literature search"| PubMed
    Yuanpan -.->|"preprint search"| BioRxiv
    Yizheng -.->|"verification"| PubMed
    Yizheng -.->|"verification"| BioRxiv

    %% ── Dashboard ──
    DB -->|"read-only"| Dashboard

    %% ── Trial Pipeline Result ──
    Approved -->|"activate"| Shixiao

    %% ── Styles ──
    classDef userStyle fill:#FFFFFF,stroke:#C41E3A,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef orchStyle fill:#FFF8E7,stroke:#DAA520,stroke-width:3px,color:#333333,rx:8,ry:8
    classDef deptStyle fill:#FFFFFF,stroke:#2E8B8B,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef trialStyle fill:#FFFFFF,stroke:#DAA520,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef engineStyle fill:#FFFFFF,stroke:#8B7355,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef infraStyle fill:#F5F5F5,stroke:#999999,stroke-width:2px,color:#555555,rx:8,ry:8
    classDef reportStyle fill:#FFFFFF,stroke:#C41E3A,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef approvedStyle fill:#F0FFF0,stroke:#2E8B57,stroke-width:2px,color:#333333,rx:8,ry:8

    class User userStyle
    class Yuyi orchStyle
    class Shiyi,Daoyin,Zhenmai,Yanfang,Bencao,Shixiao deptStyle
    class Yuanpan,Yizheng trialStyle
    class EngineMain,Patterns,Causal engineStyle
    class DB,Dashboard,USDA,PubMed,BioRxiv infraStyle
    class Baogao reportStyle
    class Approved approvedStyle

    style ORCH fill:#FFF8E7,stroke:#DAA520,stroke-width:3px,color:#333333
    style DEPTS fill:#F0FAFA,stroke:#2E8B8B,stroke-width:2px,color:#333333
    style TRIAL fill:#FFFBF0,stroke:#DAA520,stroke-width:2px,color:#333333
    style ENGINE fill:#FAF5F0,stroke:#8B7355,stroke-width:2px,color:#333333
    style APIS fill:#F5F5F5,stroke:#999999,stroke-width:1px,color:#555555
