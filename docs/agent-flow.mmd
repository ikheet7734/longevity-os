%%{init: {
  'theme': 'base',
  'themeVariables': {
    'fontSize': '14px',
    'fontFamily': 'system-ui, -apple-system, sans-serif',
    'primaryColor': '#FFFFFF',
    'primaryBorderColor': '#DAA520',
    'primaryTextColor': '#333333',
    'lineColor': '#555555',
    'secondaryColor': '#FFF8E7',
    'tertiaryColor': '#F5F5F5',
    'background': '#FFFFFF',
    'mainBkg': '#FFFFFF',
    'nodeBorder': '#DAA520',
    'clusterBkg': '#FAFAFA',
    'clusterBorder': '#CCCCCC',
    'titleColor': '#333333',
    'edgeLabelBackground': '#FFFFFF'
  }
}}%%
flowchart LR
    %% ── Input ──
    Input["<b>User Input</b><br/><i>'Propose an experiment<br/>for my sleep'</i>"]

    %% ── Classification ──
    Classify{"<b>御医</b> classifies<br/>intent & domain"}

    %% ── Dispatch paths ──
    subgraph DISPATCH["AGENT DISPATCH"]
        direction TB
        Simple["<b>Single Agent</b><br/><i>e.g. log meal -> 食医科</i>"]
        Multi["<b>Multi-Agent</b><br/><i>e.g. report -> 报告科<br/>+ all departments</i>"]
        Trial["<b>Trial Pipeline</b><br/><i>pattern -> trial design</i>"]
    end

    %% ── Trial Pipeline Detail ──
    subgraph PIPELINE["TRIAL DESIGN PIPELINE"]
        direction TB
        P1["<b>试效科</b> detects pattern<br/><i>modeling engine</i>"]
        P2["<b>院判</b> designs trial<br/><i>literature + stats</i>"]
        P3{"<b>医正</b> reviews"}
        P4["Approved Protocol"]
        P5["Revise"]
        P1 --> P2
        P2 --> P3
        P3 -->|"pass"| P4
        P3 -->|"fail"| P5
        P5 -->|"feedback"| P2
    end

    %% ── Result Collection ──
    Collect["<b>御医</b> collects<br/>& synthesizes results"]

    %% ── Response ──
    Response["<b>Formatted Response</b><br/>to User"]

    %% ── Flow ──
    Input --> Classify
    Classify -->|"log / query"| Simple
    Classify -->|"report / summary"| Multi
    Classify -->|"experiment / trial"| Trial

    Simple --> Collect
    Multi --> Collect
    Trial --> PIPELINE
    P4 --> Collect
    Collect --> Response

    %% ── Styles ──
    classDef userStyle fill:#FFFFFF,stroke:#C41E3A,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef orchStyle fill:#FFF8E7,stroke:#DAA520,stroke-width:3px,color:#333333,rx:8,ry:8
    classDef deptStyle fill:#FFFFFF,stroke:#2E8B8B,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef trialStyle fill:#FFFFFF,stroke:#DAA520,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef resultStyle fill:#FFFFFF,stroke:#8B7355,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef approvedStyle fill:#F0FFF0,stroke:#2E8B57,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef rejectStyle fill:#FFF5F5,stroke:#C41E3A,stroke-width:2px,color:#333333,rx:8,ry:8
    classDef decisionStyle fill:#FFF8E7,stroke:#DAA520,stroke-width:3px,color:#333333,rx:8,ry:8

    class Input,Response userStyle
    class Classify decisionStyle
    class Simple,Multi deptStyle
    class Trial trialStyle
    class P1 deptStyle
    class P2 trialStyle
    class P3 decisionStyle
    class P4 approvedStyle
    class P5 rejectStyle
    class Collect,Response resultStyle

    style DISPATCH fill:#F0FAFA,stroke:#2E8B8B,stroke-width:2px,color:#333333
    style PIPELINE fill:#FFFBF0,stroke:#DAA520,stroke-width:2px,color:#333333
